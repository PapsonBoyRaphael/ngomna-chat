NODE_ENV=development
DEV_CONFIG_MODE=simple
PORT=8003
CHAT_FILE_SERVICE_PORT=8003
SERVER_ID=chat-file-service-1
JWT_SECRET=CENADI_CHATAPP_UNIFIED_SECRET_2024
MONGODB_URI=mongodb://localhost:27017/chat_file_service

# Redis
ENABLE_REDIS=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_FAMILY=4
REDIS_KEEP_ALIVE=true
REDIS_CONNECTION_TIMEOUT=5000
REDIS_MAX_RETRY_ATTEMPTS=3
REDIS_MEMORY_LIMIT_MB=512

# Configuration du service de visibilité pour AutoGroupSyncService
VISIBILITY_PORT=5001
VISIBILITY_SERVICE_URL=http://172.31.31.214:5001

# Stockage fichiers (S3 / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chat-files
S3_REGION=us-east-1

# SFTP (optionnel)
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASS=
SFTP_REMOTE_PATH=/uploads


# Configuration de chiffrement E2EE
E2EE_ENABLED=true
E2EE_ALGORITHM=aes-256-gcm
E2EE_KEY_DERIVATION_SALT=some_random_salt_value
ENCRYPTION_MODE=none
# Intervalle de rotation des clés en ms (30 jours)
KEY_ROTATION_INTERVAL=2592000000

# Auth user service (pour pré-chauffage cache)
AUTH_USER_SERVICE_URL=http://localhost:8001

# Chemins de stockage et logs
STORAGE_BASE_PATH=./storage
STORAGE_UPLOAD_PATH=./storage/uploads
STORAGE_TEMP_PATH=./storage/temp
LOG_DIR=./logs

